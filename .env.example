# ─────────────────────────────────────────────────────────────
# DEBO — Environment variables (copy to .env.local and fill in)
# NEVER commit real secrets. Validated at runtime by src/lib/env.ts
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database (PostgreSQL / Supabase)
# DATABASE_URL uses the pooled connection; DIRECT_URL is for migrations.
DATABASE_URL="postgresql://postgres:password@localhost:5432/debo?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/debo?schema=public"

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-32-byte-random-secret"
AUTH_URL="http://localhost:3000"
# Optional OAuth (leave blank to disable the Google button)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# Upstash Redis (REST)
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxx"

# Resend (transactional + marketing email)
RESEND_API_KEY="re_xxx"
EMAIL_FROM="DEBO <commandes@debo.com>"

# Seed admin (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@debo.com"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
