// DEBO — Premium E-commerce Data Model
// PostgreSQL + Prisma. Strict FKs, indexes, and enum-driven RBAC/state machines.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase pooler vs direct migrations
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum TransactionType {
  CHARGE
  REFUND
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum NewsletterStatus {
  PENDING // awaiting double opt-in confirmation
  CONFIRMED
  UNSUBSCRIBED
}

// ============================================================
// AUTH (NextAuth / Auth.js Prisma Adapter)
// ============================================================

model User {
  id               String  @id @default(cuid())
  name             String?
  email            String  @unique
  emailVerified    DateTime?
  passwordHash     String? // null for OAuth-only accounts
  image            String?
  role             Role    @default(CUSTOMER)
  stripeCustomerId String? @unique

  accounts             Account[]
  sessions             Session[]
  addresses            Address[]
  orders               Order[]
  cart                 Cart?
  customConfigurations CustomConfiguration[]
  bespokeRequests      BespokeRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  fullName   String
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String  @db.Char(2) // ISO 3166-1 alpha-2
  phone      String?
  isDefault  Boolean @default(false)

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================================
// CATALOG
// ============================================================

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String  @db.Text
  // Monetary values stored in minor units (cents) to avoid float errors.
  basePrice   Int
  currency    String  @default("EUR") @db.Char(3)
  isActive    Boolean @default(true)
  isFeatured  Boolean @default(false)
  categoryId  String?

  category Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images   ProductImage[]
  variants Variant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isActive, isFeatured])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Variant {
  id        String  @id @default(cuid())
  productId String
  sku       String  @unique
  color     String?
  size      String?
  // Optional override; falls back to Product.basePrice when null.
  price     Int?
  inventory Int     @default(0)
  isActive  Boolean @default(true)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, color, size])
  @@index([productId])
}

// ============================================================
// CART (persistent for auth users; Redis mirrors guest carts)
// ============================================================

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique // human-friendly: DEBO-XXXXXX
  userId        String?
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(REQUIRES_PAYMENT)

  // Money snapshots in minor units, captured at purchase time.
  subtotal    Int
  discount    Int    @default(0)
  shippingFee Int    @default(0)
  tax         Int    @default(0)
  total       Int
  currency    String @default("EUR") @db.Char(3)

  couponId          String?
  shippingAddressId String?
  billingAddressId  String?

  // Snapshot contact + livraison (checkout invité, sans compte requis).
  email          String?
  shipName       String?
  shipLine1      String?
  shipLine2      String?
  shipCity       String?
  shipPostalCode String?
  shipCountry    String? @db.Char(2)
  shipPhone      String?

  stripePaymentIntentId String? @unique

  // Fulfillment
  trackingCarrier String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupon          Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  shippingAddress Address?      @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddress  Address?      @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  transactions    Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt]) // analytics range scans
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String?

  // Snapshots so historical orders survive product/price edits.
  productName String
  variantInfo String? // e.g. "Obsidian / M"
  sku         String
  unitPrice   Int
  quantity    Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ============================================================
// PAYMENTS & REFUNDS
// ============================================================

model Transaction {
  id       String          @id @default(cuid())
  orderId  String
  type     TransactionType
  amount   Int // minor units; positive for charge, positive refunded amount
  currency String          @default("EUR") @db.Char(3)
  status   PaymentStatus

  stripeChargeId        String?
  stripePaymentIntentId String?
  stripeRefundId        String? @unique
  reason                String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([type])
}

// ============================================================
// MARKETING
// ============================================================

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  value          Int // percent (0–100) or fixed minor units
  minOrder       Int? // minimum subtotal to qualify (minor units)
  maxRedemptions Int?
  timesRedeemed  Int        @default(0)
  isActive       Boolean    @default(true)
  startsAt       DateTime?
  expiresAt      DateTime?

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, expiresAt])
}

model NewsletterSubscriber {
  id             String           @id @default(cuid())
  email          String           @unique
  status         NewsletterStatus @default(PENDING)
  confirmToken   String?          @unique // double opt-in token
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  source         String? // e.g. "footer_widget"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ============================================================
// SUR-MESURE & HAUTE JOAILLERIE
// (perles facettées / pierres précieuses configurées + pièces uniques)
// ============================================================

enum GemKind {
  PEARL // perle de culture facettée
  GEMSTONE // pierre précieuse
}

enum MountingType {
  NONE // pierre/perle nue
  RING
  NECKLACE
  PENDANT
  EARRINGS
  BRACELET
}

enum ConfigStatus {
  DRAFT // brouillon visiteur
  SUBMITTED // demande envoyée
  QUOTED // devis proposé
  ACCEPTED // devis accepté
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

enum BespokeStatus {
  NEW
  REVIEWING
  QUOTED
  ACCEPTED
  IN_PRODUCTION
  DELIVERED
  CANCELLED
}

/// Configuration sur-mesure d'une perle facettée ou d'une pierre précieuse.
model CustomConfiguration {
  id     String  @id @default(cuid())
  userId String?

  gemKind      GemKind
  diagram      String // diagramme de facettage unique (référence/nom)
  faceting     String // type de taille / facettage
  dimensionsMm Float // dimension principale en millimètres
  color        String // teinte souhaitée
  mounting     MountingType @default(NONE)
  notes        String?      @db.Text

  estimatedPrice Int? // devis en minor units (centimes)
  status         ConfigStatus @default(DRAFT)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Demande de pièce unique en haute joaillerie (avec fichiers d'inspiration).
model BespokeRequest {
  id     String  @id @default(cuid())
  userId String?

  contactName  String
  contactEmail String
  phone        String?

  materials   String[] // matériaux précieux souhaités (or, platine…)
  stones      String[] // pierres souhaitées
  description String   @db.Text
  budgetMin   Int? // fourchette budget en centimes
  budgetMax   Int?

  status BespokeStatus @default(NEW)

  files BespokeFile[]
  user  User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Fichier d'inspiration (image ou PDF) attaché à une demande haute joaillerie.
model BespokeFile {
  id        String @id @default(cuid())
  requestId String
  url       String
  fileName  String
  mimeType  String
  sizeBytes Int

  request BespokeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([requestId])
}

enum DevisStatus {
  NEW // nouvelle demande
  REVIEWED // étudiée par Clarisse
  QUOTED // devis envoyé
  ACCEPTED // accepté
  CLOSED // close / archivée
}

/// Diagramme de taille géré depuis l'admin (transcription d'un diagramme PDF).
/// `program` = liste des facettes [{tier, angle, index, depth, repeat}].
/// Affiché sur le front ; le visiteur l'ajuste via les réglages grand public.
model CutDiagram {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  family      String // "pierre" | "perle"
  description String?
  pdfUrl      String? // lien vers le PDF source (référence)

  program Json // FacetInstruction[]
  scaleX  Float @default(1) // silhouette (allongement)
  scaleZ  Float @default(1)
  gear    Int   @default(96) // denture de la roue d'index (GemCAD)

  // Portée : disponible pour TOUTES les pierres / TOUTES les perles, et/ou
  // pour des matières spécifiques (via la table de jointure StoneDiagram).
  appliesToAllStones Boolean @default(false)
  appliesToAllPearls Boolean @default(false)

  published Boolean @default(false)
  isSystem  Boolean @default(false) // diagrammes seedés (6 tailles d'origine)
  sortOrder Int     @default(0)

  materials StoneDiagram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
  @@index([family])
}

/// Matière brute gérée depuis l'admin : pierre précieuse ou perle de culture.
/// `appearance` = id d'une apparence du catalogue (texture/optique).
model GemMaterial {
  id         String  @id @default(cuid())
  slug       String  @unique
  name       String
  kind       String // "pierre" | "perle"
  appearance String // id du catalogue d'apparences
  colorHex   String
  blurb      String?

  published Boolean @default(false)
  isSystem  Boolean @default(false)
  sortOrder Int     @default(0)

  diagrams StoneDiagram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
  @@index([kind])
}

/// Jointure matière ⇄ diagramme (assignations spécifiques).
model StoneDiagram {
  materialId String
  diagramId  String

  material GemMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  diagram  CutDiagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  @@id([materialId, diagramId])
  @@index([diagramId])
}

/// Demande de devis du configurateur sur-mesure, avec fiche technique lapidaire.
model DevisRequest {
  id String @id @default(cuid())

  // Contact
  contactName  String
  contactEmail String
  phone        String?

  // Sélection au configurateur
  gemKind          String // "pierre" | "perle"
  stone            String
  cut              String
  mounting         String
  material         String?
  goldCarat        String?
  grammage         String?
  occasion         String?
  message          String? @db.Text
  inspirationCount Int     @default(0)

  // Fiche technique (colonnes rapides pour le listing admin)
  caratWeight   Float?
  diameterMm    Float?
  lengthMm      Float?
  depthMm       Float?
  tablePercent  Float?
  crownAngle    Float?
  pavilionAngle Float?
  mainFacets    Int?
  girdleFacets  Int?

  // Fiche complète (programme de facettage, optique, résumé…)
  spec Json?

  status DevisStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
